~~ Riven Core System Header v1.0
~~ Provides standard metadata for the Native Compiler Toolchain

firm RIVEN_VERSION = 1.0
firm RIVEN_STDLIB_REV = 1
firm RIVEN_BACKEND = "C11/GCC"

